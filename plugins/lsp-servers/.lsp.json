{
  "typescript": {
    "command": "typescript-language-server",
    "args": ["--stdio"],
    "extensionToLanguage": {
      ".ts": "typescript",
      ".tsx": "typescriptreact",
      ".js": "javascript",
      ".jsx": "javascriptreact"
    }
  },
  "python": {
    "command": "pyright-langserver",
    "args": ["--stdio"],
    "extensionToLanguage": {
      ".py": "python"
    }
  },
  "go": {
    "command": "gopls",
    "args": ["serve"],
    "extensionToLanguage": {
      ".go": "go"
    }
  }
  "cpp": {
    "command": "clangd-15",
    "args": [
      "--background-index",
      "--header-insertion=never",
      "--query-driver=/usr/bin/arm-none-eabi-gcc*"
    ],
    "extensionToLanguage": {
      ".c": "cpp",
      ".h": "cpp",
      ".cpp": "cpp",
      ".hpp": "cpp"
    }
  }
}
